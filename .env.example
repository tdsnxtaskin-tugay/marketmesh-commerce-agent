# ─────────────────────────────────────────────────────────────────────────────
# MarketMesh — example environment. Copy to `.env` and fill in.
# NEVER commit a real .env. Every value below is optional: when unset, the agent
# degrades gracefully to deterministic offline behaviour so the demo always runs.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (optional — used for natural-language reasoning narration) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# ── Fabric IQ (optional — semantic product ontology / knowledge graph) ──
# When unset, MarketMesh builds an in-memory ontology from the local sample graph.
FABRIC_IQ_ENDPOINT=
FABRIC_IQ_WORKSPACE=
FABRIC_IQ_ONTOLOGY=software-commerce
FABRIC_IQ_API_KEY=

# ── Foundry IQ (optional — grounded retrieval over product knowledge) ──
# When unset, MarketMesh answers from the local sample knowledge with citations.
FOUNDRY_IQ_PROJECT_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_SOURCE=
FOUNDRY_IQ_API_KEY=

# ── Work IQ (optional — Microsoft Graph buyer signals) ──
# When unset, MarketMesh reads samples/work_iq_signals.json.
WORK_IQ_TENANT_ID=
WORK_IQ_CLIENT_ID=
WORK_IQ_CLIENT_SECRET=
WORK_IQ_USER_ID=

# ── Commerce safety knobs ──
DRY_RUN=true
MAX_TRANSACTION_USD=500000
DEFAULT_CURRENCY=USD
DEFAULT_BUDGET_USD=900000
